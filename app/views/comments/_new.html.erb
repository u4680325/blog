<%= form_with model: [ post, Comment.new ], id: "post_comment" do |form| %>
  <div style="display:flex;">
    <%= form.text_field :content, autofocus: true, style: "min-width:calc(100% - 40px);" %>
    <%= image_submit_tag("send-icon.svg", height: "38", style: "padding:6px;border:none;") %>
    <%#= form.submit "Reply" %>
  </div>
<% end %>
<script>
  (function() {
    const form = document.getElementById("post_comment");

    form.addEventListener("submit", (event) => {
      form.submit();
      const formData = new FormData(form);
      const formObject = Object.fromEntries(formData);
      const content = formObject["comment[content]"];
      if (content.startsWith("/") && content.length == 2 ) {
        console.log("is_command")
      } else {
        form.reset();
      }
    });
  })();
</script>